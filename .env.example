# Copy this file to .env in the project root and fill in your Google credentials.
# IMPORTANT: the redirect URI must exactly match the URL you use in the browser.
# Example for Django runserver default:
# http://127.0.0.1:8000/auth/google/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
